{
  "name": "@paperxent/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "node scripts/with-root-env.mjs generate --schema prisma/schema.prisma",
    "db:migrate": "node scripts/with-root-env.mjs migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "node scripts/with-root-env.mjs migrate deploy --schema prisma/schema.prisma",
    "db:studio": "node scripts/with-root-env.mjs studio --schema prisma/schema.prisma",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv": "^16.4.5",
    "prisma": "5.22.0"
  }
}
