# Build from repository root: docker build -f deploy/Dockerfile.web .
FROM node:20-bookworm-slim
WORKDIR /app

RUN apt-get update && apt-get install -y openssl ca-certificates && rm -rf /var/lib/apt/lists/*

COPY . .
RUN npm ci && npm run db:generate && npm run build -w @paperxent/web

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
EXPOSE 3000
CMD ["npm", "run", "start", "-w", "@paperxent/web"]
