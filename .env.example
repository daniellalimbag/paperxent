NODE_ENV=development

# Apps
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Next.js server → Express (Route Handlers + /proxy). In Docker use the internal service URL, e.g. http://api:4000
API_INTERNAL_URL=http://localhost:4000

# API JWT signing (required in production; change from any dev default)
JWT_SECRET=change-me-in-production

# Infrastructure
DATABASE_URL=postgresql://paperxent:paperxent@localhost:5432/paperxent?schema=public
REDIS_URL=redis://localhost:6379
