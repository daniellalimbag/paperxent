NODE_ENV=development

# Apps
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Next.js server → Express (Route Handlers + /proxy). In Docker use the internal service URL, e.g. http://api:4000
API_INTERNAL_URL=http://localhost:4000

# API JWT signing (required in production; change from any dev default)
JWT_SECRET=change-me-in-production

# Infrastructure
DATABASE_URL=postgresql://paperxent:paperxent@localhost:5432/paperxent?schema=public
REDIS_URL=redis://localhost:6379

# Optional: live EOD quotes + daily history charts (Marketstack — https://marketstack.com/)
# When set, the API uses Marketstack for trading, discover, and portfolio valuation.
# MARKETSTACK_ACCESS_KEY=

# Optional: max age (ms) of a live quote before trade preview/execute reject as stale (default 300000 = 5 min)
# QUOTE_MAX_AGE_MS=300000

# Note: The API loads both this repo-root .env and apps/api/.env (apps/api wins on duplicates).
# MARKETSTACK_ACCESS_KEY must be visible to the Node process that runs apps/api (not only Next.js).

# Optional: Gemini trade analysis after paper trades (Google AI Studio free tier — https://aistudio.google.com/apikey)
# When set, post-trade insights use Gemini; metrics still come from the server. Falls back to rules if the call fails.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
